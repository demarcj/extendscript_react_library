{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowArbitraryExtensions": true,
    "skipLibCheck": true
  },
  "include": [
    "ts/library/cep_panel/**/*.d.ts",
    "tsx/**/*.ts",
    "tsx/**/*.tsx",
    "tsx/**/*.d.ts",
    "tsx/**/*.css"
  ]
}
